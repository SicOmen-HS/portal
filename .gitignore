# Se docs/05_Konfiguration.md för fullständiga principer.

# Node / Angular
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.angular/
frontend/coverage/

# Worksmith runtime lock file (created/removed automatically during mutating commands)
.worksmith-mutation.lock

# Lokal, ej versionshanterad konfiguration
**/appsettings.Local.json
**/appsettings.Development.json
**/appsettings.Production.json
**/environment.ts
**/environment.local.ts
**/runtime-config.local.json
**/secrets.json
.env
.env.*

# Certifikat och nycklar
*.pfx
*.pem
*.key
*.crt
*.cer

# IDE / systemfiler
# .vscode/extensions.json innehåller inga secrets och delas medvetet
# (se docs/14_Rekommenderade_extensions.md) — övriga .vscode-filer kan
# innehålla lokala/personliga sökvägar och ignoreras därför.
.vscode/*
!.vscode/extensions.json
.idea/
*.user
*.suo
.DS_Store
Thumbs.db
