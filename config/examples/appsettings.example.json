  "_comment": "Mall för framtida backend-konfiguration (.NET Web API). Används inte av denna frontend-mockup, men visar avsedd struktur enligt docs/05_Konfiguration.md.",
  "ConnectionStrings": {
    "Default": "<DATABASE_CONNECTION_STRING>"
  },
  "Services": {
    "OpenMetadata": "<OPENMETADATA_URL>",
    "QlikSense": "<QLIK_SENSE_URL>",
